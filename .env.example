# ──────────────────────────────────────────────────────────────────────────
# LINDA — environment variable reference
#
# Copy to .env and fill in the values you need. Every variable has a
# sensible default (empty string = "feature disabled") except the three
# required ones called out at the top of each section.
#
# Variables split into two buckets:
#
# 1. **Runtime env vars** — the API + worker containers read these at
#    boot. Host them wherever you deploy (Fly secrets, ECS parameter
#    store, Kubernetes secret, Render env group, etc.).
# 2. **GitHub Actions secrets/variables** — referenced only by
#    .github/workflows/ci-cd.yml. Those belong in repo Settings →
#    Secrets and variables → Actions.
#
# See docs/deployment.md for a step-by-step on where each value lives.
# ──────────────────────────────────────────────────────────────────────────


# ── Core (required) ───────────────────────────────────────────────────
APP_NAME=LINDA
DEBUG=false
ENVIRONMENT=local                          # local | staging | production
RELEASE_VERSION=                           # CI populates with the commit SHA
# CORS — JSON list of origins. MUST be set explicitly in every
# environment (the runtime default is ``[]``). Browsers reject
# wildcard origins paired with credentialed requests, so don't ship a
# "*" here. Examples:
#   local:   ["http://localhost:3000"]
#   staging: ["https://linda-staging-app.fly.dev"]
#   prod:    ["https://app.linda.example.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# Postgres. Neon, RDS, Supabase, or a local docker container all work.
# asyncpg driver is required.
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/linda

# Redis — used for Celery broker/backend, live-coaching pub/sub, and
# rate limiting. Upstash / ElastiCache / managed Redis all fine.
REDIS_URL=redis://localhost:6379/0

# JWT used to sign dashboard session tokens. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
SESSION_JWT_SECRET=
SESSION_JWT_TTL_HOURS=12

# Fernet key used to encrypt OAuth tokens + API keys at rest. Generate:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Rotate via the two-key dance in docs/runbook.md §5.
TOKEN_ENCRYPTION_KEY=


# ── AI / LLM (required) ────────────────────────────────────────────────
# Anthropic Claude — every analysis pass runs through Claude.
ANTHROPIC_API_KEY=


# ── Speech-to-text (required for voice) ────────────────────────────────
# Deepgram — live + batch ASR with native diarization. Primary engine.
DEEPGRAM_API_KEY=
DEFAULT_TRANSCRIPTION_ENGINE=deepgram      # deepgram | whisper

# Hugging Face token — needed to download pyannote's speaker-diarization
# model on first run. Generate a read token and accept the model's
# licence at https://hf.co/pyannote/speaker-diarization-3.1.
HUGGINGFACE_TOKEN=
PYANNOTE_DIARIZATION_MODEL=pyannote/speaker-diarization-3.1


# ── Observability ──────────────────────────────────────────────────────
# Sentry DSN — empty disables error monitoring (fine for local).
SENTRY_DSN=


# ── Vector DB + embeddings (required for KB search) ───────────────────
VECTOR_BACKEND=pgvector                    # pgvector | qdrant

# Qdrant — only needed when VECTOR_BACKEND=qdrant.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Voyage AI — embedding model used by the KB pipeline.
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3
VOYAGE_EMBED_DIM=1024

# Chunk sizing. Defaults are sane; tune for your corpus.
KB_CHUNK_TOKENS=500
KB_CHUNK_OVERLAP_TOKENS=80


# ── Search (optional) ──────────────────────────────────────────────────
# Elasticsearch powers transcript full-text search. When omitted, we
# fall back to Postgres FTS — slower but still works.
ELASTICSEARCH_URL=http://localhost:9200


# ── Auth (required unless you build your own auth layer) ──────────────
# Clerk — managed auth provider. Get both keys from clerk.com → API keys.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=


# ── Telephony (optional — enable the providers you use) ───────────────
# Twilio. Account SID + auth token grant inbound webhook verification
# AND outbound programmatic control. We don't originate calls, so
# auth_token is used only for webhook signature checks.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# SignalWire — same API shape as Twilio.
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_TOKEN=

# Telnyx — Call Control. Get API key from the Telnyx portal.
TELNYX_API_KEY=


# ── KB providers (optional — any subset) ──────────────────────────────
# Google Drive / Docs OAuth. Create an OAuth client at
# https://console.cloud.google.com/ with the drive.readonly scope.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Graph OAuth — covers OneDrive + SharePoint. App registration:
# https://portal.azure.com → Microsoft Entra ID → App registrations.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=


# ── CRM providers (optional — any subset) ─────────────────────────────
# HubSpot — CRM v3 API. App: https://developers.hubspot.com → Create app.
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Salesforce — OAuth 2.0 connected app.
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Pipedrive — OAuth 2.0 marketplace app.
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=


# ── Billing (required for paid plans) ──────────────────────────────────
# Stripe — get keys from dashboard.stripe.com → Developers → API keys.
# Webhook secret: Developers → Webhooks → the endpoint you created.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional second signing secret accepted in parallel during a webhook-
# secret rotation. See backend/app/services/stripe_billing.py docstring
# for the rotation procedure. Leave blank when not rotating.
STRIPE_WEBHOOK_SECRET_NEXT=
# Price IDs for each tier. Create products/prices in Stripe first, then
# paste the price_xxx IDs here.
STRIPE_PRICE_SANDBOX=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=


# ── Enrichment (optional) ──────────────────────────────────────────────
PDL_API_KEY=                               # People Data Labs
APOLLO_API_KEY=


# ── Email ingest (optional) ────────────────────────────────────────────
# Only set when a tenant wants Gmail / Graph push notifications. See
# docs/runbook.md §6 for the PubSub setup details.
GMAIL_PUBSUB_TOPIC=
GMAIL_PUSH_TOKEN=
GRAPH_CLIENT_STATE=
EMAIL_POLL_FORCE_ALL=false


# ── WhatsApp (optional) ────────────────────────────────────────────────
META_WHATSAPP_TOKEN=
META_VERIFY_TOKEN=


# ── Recall.ai meeting-bot (optional) ───────────────────────────────────
RECALL_AI_API_KEY=


# ── Object storage (required for file uploads) ─────────────────────────
# S3 staging bucket — briefly holds uploaded audio files between ingest
# and transcription. Set up the bucket with private ACL + lifecycle rule
# to auto-delete objects older than 24h as a belt-and-braces for the
# per-task cleanup we already do.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=                             # e.g., linda-staging-audio


# ── Webhooks (required if tenants want outbound webhook delivery) ─────
PUBLIC_WEBHOOK_BASE_URL=                   # e.g., https://api.linda.example.com


# ── Alert routing (optional) ───────────────────────────────────────────
GITHUB_ALERT_REPO=                         # e.g., davisfox5/test-5
GITHUB_ALERT_TOKEN=


# ── Worker runtime tuning (optional) ───────────────────────────────────
# Set LINDA_WORKER_WARMUP=0 on beat-only workers that don't run audio
# tasks, so they skip the 1-2 minute model preload.
LINDA_WORKER_WARMUP=1

# Where SpeechBrain caches the emotion model. Defaults to
# ~/.cache/linda/emotion-iemocap.
LINDA_EMOTION_MODEL_DIR=


# ── Paralinguistic tests (CI only) ─────────────────────────────────────
# Set to 1 in CI to skip the end-to-end SpeechBrain tests (avoids the
# 1 GB model download on every test run).
LINDA_EMOTION_TESTS_DISABLED=0


# ── Logging ────────────────────────────────────────────────────────────
LOG_FORMAT=text                            # text | json
LOG_LEVEL=INFO


# ── Sentry sampling (production only) ──────────────────────────────────
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
